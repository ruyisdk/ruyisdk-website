  "about.intro.title": { "message": "关于我们" },
  "about.project.title": { "message": "项目介绍" },
  "about.project.description": { "message": "RUYISDK 是一款专为 RISC-V 开发者打造的全方位、集成式全功能开发环境。RUYISDK 由中国科学院软件研究所（ISCAS）主导，旨在为 RISC-V 开发者提供一站式的开发解决方案。本项目从 2022 年下半年开始筹划，从 2024 年年初起变更为双周发布的敏捷开发方式。项目启动以来，我们不断优化产品，致力于为广大 RISC-V 开发者提供优质的服务。" },
  "about.goals.title": { "message": "核心目标" },
  "about.goals.item1": { "message": "开发者购买了（几乎）任何一款 RISC-V 开发板或模组，都可以通过 RUYISDK 系统获得硬件资料说明、固件/软件更新、调试支持等。" },
  "about.goals.item2": { "message": "开发者可以指定任何常用的 RISC-V 扩展指令集架构组合，都可以通过 RUYISDK 系统生成客户所需的操作系统、工具链、语言执行环境（运行时或虚拟机）、计算库、应用框架等。" },
  "about.goals.item3": { "message": "培育运营一个活跃全面的开发者交流社区。" },
  "about.products.title": { "message": "我们的产品" },
  "about.products.revyos": { "message": "RISC-V 操作系统（XuanTie 芯片优化定制发行版）：RevyOS" },
  "about.products.ruyi": { "message": "RISC-V 包管理器：ruyi" },
  "about.products.provision": { "message": "RISC-V 操作系统安装工具：ruyi device provision" },
  "about.products.ide": { "message": "RISC-V IDE：RuyiSDK IDE" },
  "about.products.toolchains": { "message": "RISC-V 编译工具链：PLCT-GCC、PLCT-LLVM" },
  "about.products.software.title": { "message": "重点参与 RISC-V 适配和支持的软件（已集成到 RuyiSDK 软件源的部分）：" },
  "about.opensource.title": { "message": "开源贡献与社区" },
  "about.opensource.description1": { "message": "RUYISDK 项目采用开源管理模式，代码托管于 GitHub。我们欢迎广大开发者参与项目，共同推动 RISC-V 技术的发展。" },
  "about.opensource.description2": { "message": "RUYISDK 社区旨在建设一个开放、友善、多样化、包容、健康活跃的社区。" },
  "about.opensource.description3": { "message": "我们正在寻找有激情、有才华的您加入我们的团队。如果您对 RISC-V 技术充满热情，欢迎投递简历至：吴老师 wuwei2016@iscas.ac.cn。" },
  "about.opensource.description4": { "message": "在参与社区讨论前，请先查阅社区守则以便更好地在社区内交流。" },
  "about.opensource.codeOfConduct": { "message": "社区守则" },
